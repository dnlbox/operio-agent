# ==============================================================================
# Operio Mall Operations SRE Agent Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Reasoning backend
# Use "adk" for Google Cloud Agent Builder / ADK runtime integration.
OPERIO_REASONING_BACKEND=adk

# Google Cloud Agent Builder / Vertex AI configuration
# These settings let ADK route Gemini calls through Google Cloud using ADC.
# Authenticate locally with:
#   gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=operio-agent-260608-3d6b
GOOGLE_CLOUD_LOCATION=us-central1

# Legacy Gemini API fallback
# Only required if OPERIO_REASONING_BACKEND=legacy.
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# MongoDB Connection Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB=operio

# Arize Phoenix Telemetry Tracing Configuration
PHOENIX_PROJECT_NAME=operio-agent

# Arize AX Hosted Platform Credentials
# Set these to export telemetry and evaluation logs to Arize AX Cloud.
# When both are present, tracing is enabled; otherwise tracing is skipped.
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Arize Phoenix MCP Server Command
# Exposes Phoenix datasets, experiments, and traces directly to the agent.
PHOENIX_MCP_COMMAND=["npx", "-y", "@arizeai/phoenix-mcp"]


